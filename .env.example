# Create a .env file and copy everything

## -- Required --
# You must set this to "true" to accept the Minecraft EULA:
EULA=true

## -- JVM / performance --
# Heap size for -Xms/-Xmx Leave ~1-1.5GB of headroom below your container's memory limit/host RAM
# the JVM and OS need room beyond the heap itself.
MEMORY=4G
# EXTRA_JAVA_ARGS=-Dpaper.playerconnection.keepalive=60

## -- Paper version --
# Minecraft version
MC_VERSION=latest

# BUILD TIME ONLY
# changing this needs docker compose up -d --build or docker build --build-arg JAVA_VERSION=..
JAVA_VERSION=25
PAPER_BUILD=latest
PAPER_CHANNEL=STABLE

## -- Bedrock crossplay --
GEYSER_ENABLED=true
FLOODGATE_ENABLED=true
HURRICANE_ENABLED=true
SKIN_MANAGER_ENABLED=true
GEYSER_PORT=19132

## -- server.properties (only applied on first run) --
SERVER_PORT=25565
MOTD=Minecraft crossplay server
DIFFICULTY=normal
GAMEMODE=survival
MAX_PLAYERS=20
ONLINE_MODE=true
WHITE_LIST=false
PVP=true
ALLOW_FLIGHT=false
VIEW_DISTANCE=10
SIMULATION_DISTANCE=10
LEVEL_NAME=world
LEVEL_SEED=
SPAWN_PROTECTION=0
ENABLE_COMMAND_BLOCK=false

## -- RCON --
ENABLE_RCON=false
RCON_PORT=25575
RCON_PASSWORD=

## -- Container user --
# UID/GID match this to your host
PUID=1000
PGID=1000
